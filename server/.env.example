# APeer Server — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# -----------------------------------------------
# Blockfrost (Cardano indexer)
# Get a key at https://blockfrost.io
# Use the "Cardano preprod" project for development
# -----------------------------------------------
BLOCKFROST_PROJECT_ID=preprodYOUR_KEY_HERE

# -----------------------------------------------
# Server
# -----------------------------------------------
PORT=3000
NODE_ENV=development

# -----------------------------------------------
# IPFS Pinning (web3.storage or Pinata)
# Leave blank for now — wired in a later increment
# -----------------------------------------------
WEB3_STORAGE_TOKEN=
