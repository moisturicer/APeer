# APeer Server — Environment Variable Template
# Copy this file to server/.env and fill in your values.
# NEVER commit server/.env to version control.

# -----------------------------------------------
# Blockfrost (Cardano indexer)
# Get a key at https://blockfrost.io
# Use the "Cardano preprod" project for development
# Key must start with "preprod" during development
# -----------------------------------------------
BLOCKFROST_PROJECT_ID=
# -----------------------------------------------
# Server
# -----------------------------------------------
PORT=3000
NODE_ENV=development

# CORS — production only; dev uses Vite proxy
# ALLOWED_ORIGIN=https://apeer.app

# -----------------------------------------------
# IPFS Pinning (Pinata)
# Get credentials at https://app.pinata.cloud/developers/api-keys
# -----------------------------------------------
PINATA_JWT=PINATA_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..Q81OW39kNkkX5_sMuXNHoe_cUIR85YIZyxVMG2HO9WY
IPFS_PROVIDER=pinata
IPFS_GATEWAY_URL=https://ipfs.io/ipfs
MAX_PAPER_SIZE_MB=50

# -----------------------------------------------
# SQLite database (relative to server/ working directory)
# -----------------------------------------------
DATABASE_PATH=./data/apeer.db

# -----------------------------------------------
# Cardano native token policy ID — Increment 3+
# PLACEHOLDER for dev/testing only — this ID matches no real token.
# Replace with the deployed Cardano native token policy ID before mainnet.
# -----------------------------------------------
# 56 hex chars = 28 bytes = correct length for a Cardano policy ID (Blake2b-224 hash)
PEERA_POLICY_ID=00000000000000000000000000000000000000000000000000000000
