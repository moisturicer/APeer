{
  "name": "apeer",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:client": "bun run --cwd client dev",
    "dev:server": "bun run --cwd server dev",
    "build": "bun run --cwd client build && bun run --cwd server build",
    "lint": "bun run --cwd client lint && bun run --cwd server lint",
    "test": "bun run --cwd client test && bun run --cwd server test",
    "setup": "bun install"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0"
  },
  "dependencies": {
    "@blockfrost/blockfrost-js": "^6.1.1",
    "@meshsdk/core": "^1.9.0-beta.102",
    "motion": "^12.38.0",
    "vite-plugin-node-polyfills": "^0.26.0"
  }
}